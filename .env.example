# Leadops Environment Configuration
# Copy this file to .env and fill in your values.

# Encryption key for session state files.
# Generate with: python -c "from session_encrypt import make_key_from_secret; print(make_key_from_secret('your-secret'))"
SESSION_ENCRYPT_KEY=

# API key for authenticating requests to the backend API.
# Set to a non-empty value to enable API key authentication.
API_KEY=

# Host and port for the backend API server.
HOST=127.0.0.1
PORT=8000

# Logging level. Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
