{
    "browser": {
        "headless": true,
        "timeout": 5000,
        "retry_count": 2,
        "min_delay": 1.0,
        "max_delay": 5.0,
        "concurrency": 2,
        "viewport_width": 1920,
        "viewport_height": 1080,
        "user_agent": "",
        "locale": "en-US",
        "timezone_id": "America/New_York",
        "geolocation": {
            "latitude": 40.7,
            "longitude": -74.0
        }
    },
    "session": {
        "storage_path": "sessions",
        "state_file": "auth_state.json",
        "auto_save": true
    },
    "export": {
        "format": "csv",
        "encoding": "utf-8-sig"
    },
    "logging": {
        "level": "WARN",
        "file": "logs/system.log",
        "max_bytes": 10485760,
        "backup_count": 5,
        "format": "%(asctime)s | %(levelname)-8s | %(name)s | %(message)s"
    },
    "paths": {
        "exports": "exports",
        "screenshots": "screenshots",
        "temp": "temp",
        "sessions": "sessions"
    }
}